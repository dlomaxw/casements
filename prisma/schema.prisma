generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id              String      @id @default(cuid())
  fullName        String
  email           String?
  phone           String? // optional: general contact enquiries have no phone
  productCategory String // "general-enquiry" for contact-form messages
  projectSize     ProjectSize? // null for general contact enquiries
  timeline        String?
  message         String?
  sourcePage      String?
  status          LeadStatus  @default(NEW)
  assignedToId    String?
  assignedTo      User?       @relation(fields: [assignedToId], references: [id])
  followUpDate    DateTime?
  notes           String?
  activities      Activity[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Activity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id])
  type      String // STATUS_CHANGE | NOTE | EMAIL_SENT | CALL_LOGGED
  note      String?
  createdAt DateTime @default(now())
}

model User {
  id             String          @id @default(cuid())
  name           String
  email          String          @unique
  // Not in the original doc schema, but required for NextAuth credentials login
  passwordHash   String?
  whatsappNumber String?
  title          String? // e.g. "Sales Director — Kampala HQ"
  role           Role            @default(SALES_REP)
  active         Boolean         @default(true)
  // Notification preferences (Settings dashboard)
  notifyEmail     Boolean @default(true)
  notifyDesktop   Boolean @default(false)
  notifyInventory Boolean @default(false)
  leads          Lead[]
  productMap     RepProductMap[]
  posts          Post[]
  media          Media[]
}

model Post {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  excerpt     String?
  body        String // markdown / plain text
  coverImage  String? // image URL
  videoUrl    String? // YouTube / Vimeo / other embed link
  category    String     @default("News")
  status      PostStatus @default(DRAFT)
  authorId    String?
  author      User?      @relation(fields: [authorId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  publishedAt DateTime?
}

model Media {
  id           String   @id @default(cuid())
  url          String
  filename     String
  contentType  String?
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())
}

// Editable website content blocks (developer/marketing CMS).
// key mirrors lib/content.ts registry, e.g. "home.hero.title".
model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// Product catalogue — managed from /crm/products (replaces the hardcoded list).
model Product {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  shortTitle      String
  description     String // card / index blurb
  longDescription String // detail-page overview
  image           String // main image
  imageAlt        String?
  videoUrl        String? // YouTube / Vimeo link
  subItems        String[] // feature list
  gallery         Json? // [{ src, alt }]
  keywords        String[]
  order           Int      @default(0)
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// §9.1 of the docs: assignLeadToRep looks up rep_product_map for the category
model RepProductMap {
  id       String @id @default(cuid())
  category String @unique // product slug, e.g. "aluminium-doors-and-windows"
  userId   String
  user     User   @relation(fields: [userId], references: [id])
}

enum LeadStatus {
  NEW
  CONTACTED
  SITE_ASSESSED
  QUOTED
  WON
  LOST
}

enum ProjectSize {
  SMALL
  MEDIUM
  LARGE
  COMMERCIAL
}

enum Role {
  ADMIN
  MANAGER
  DEVELOPER
  MARKETING
  SALES_REP
}

enum PostStatus {
  DRAFT
  PUBLISHED
}
